{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "noEmit": true,
    "isolatedModules": true,

	// TODO: Remove below lines when done with jsx => tsx conversion
    "allowJs": true,
	"checkJs": false,

	// TODO: Uncomment below lines when done with jsx => tsx conversion
	// "allowJs": false,
    // "checkJs": false,

    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@ui/*": ["src/Components/ui/*"],
      "@/*": ["src/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "eslint.config.ts"
  ]
}